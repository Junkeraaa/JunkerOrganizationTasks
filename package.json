{
  "name": "jk-organization",
  "displayName": "JK Organization Tasks",
  "description": "Gerenciador de tarefas para sprints diárias dentro do VSCode",
  "version": "0.1.0",
  "publisher": "jk-organization",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:jkOrganization.openPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jkOrganization.openPanel",
        "title": "JK Organization: Abrir Painel",
        "icon": "$(checklist)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jkOrganization",
          "title": "JK Organization Tasks",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "jkOrganization": [
        {
          "id": "jkOrganizationTasks",
          "name": "Tarefas do Dia",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "jkOrganization.openPanel",
          "when": "view == jkOrganizationTasks",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.x",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
